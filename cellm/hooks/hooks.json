{
  "description": "CELLM Oracle hooks for context capture, memory persistence, and AI analysis",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-oracle.sh",
            "timeout": 15
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hooks/init",
            "timeout": 5
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hooks/context",
            "timeout": 8
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/capture-prompt.sh",
            "timeout": 3,
            "async": true
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/knowledge/inject",
            "timeout": 3
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hooks/specs",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hooks/check-tags",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/version-guard.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|Read|Grep|Glob|NotebookEdit|WebFetch|WebSearch|Task",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/track-tool-use.sh",
            "timeout": 3,
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-file-context.sh",
            "timeout": 1
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hooks/plan-guardian",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-boundary-drift.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hooks/spec-reconcile",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/capture-context.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/capture-context.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
