{
  "description": "CELLM Oracle hooks for context capture, memory persistence, and AI analysis",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-oracle.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/configure-otel.sh",
            "timeout": 1
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/init-session.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-context.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/capture-prompt.sh",
            "timeout": 1
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/knowledge/inject",
            "timeout": 3
          },
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/arena/pending",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/inject-specs.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-node-tags.sh",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/version-guard.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash|Read|Grep|Glob|NotebookEdit|WebFetch|WebSearch|Task",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hook/track-tool-use",
            "timeout": 1
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/check-file-context.sh",
            "timeout": 1
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hook/capture-context",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:31415/api/hook/capture-context",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
